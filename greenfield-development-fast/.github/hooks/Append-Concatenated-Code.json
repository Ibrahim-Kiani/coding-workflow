{
  "hooks": {
    "SessionStart": [
    	{
			"type": "command",
			"command": ".github/scripts/inject-context.sh",
			"windows": "powershell -ExecutionPolicy Bypass -File .github/scripts/inject-context.ps1"
    	}
	],
	"Stop": [
		{
			"type": "command",
			"command": "python .github/tools/code_concatenator.py; python .github/tools/token_counter.py"
		}
	]
  }
}